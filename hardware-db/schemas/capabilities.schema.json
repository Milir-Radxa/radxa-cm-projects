{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/radxa/radxa-som-projects/main/hardware-db/schemas/capabilities.schema.json",
  "title": "Hardware DB Capabilities",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "tags",
    "constraints",
    "recommended_use_cases"
  ],
  "properties": {
    "tags": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "constraints": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "recommended_use_cases": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "price_tier": {
      "type": "string",
      "description": "The estimated pricing bracket for agent comparison (e.g. sub-$50)"
    },
    "compatible_alternatives": {
      "type": "array",
      "description": "A list of competitor or alternative boards this directly replaces or is pinned compatible with (e.g. Raspberry Pi CM4)",
      "items": {
        "type": "string"
      }
    },
    "open_source_level": {
      "type": "string",
      "description": "Degree of OSHW openness for agents calculating modification risks",
      "enum": [
        "carrier_board_oshw",
        "full_oshw",
        "closed",
        "schematics_provided"
      ]
    }
  }
}